# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Gemini API
GEMINI_API_KEY=

# SMTP Configuration for Contact Form Emails
# If not set, the app will use a mock Ethereal account and print email URLs to the console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
